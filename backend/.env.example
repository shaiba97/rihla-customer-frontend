# =============================================================================
# RIHLA - Environment Configuration Example
# =============================================================================
# IMPORTANT: Copy this file to .env and update values for your environment
# NEVER commit actual .env file to repository
# NEVER expose secrets in version control
# This file is SAFE to commit - contains only placeholder values
# =============================================================================

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
# Options: development, staging, production, test
NODE_ENV=production

# =============================================================================
# MICROSERVICE PORT CONFIGURATION
# =============================================================================
# Each service runs on its own port
# In production with Render/Docker, these are internal ports
# Render will automatically expose them as needed
ADMIN_PORT=3000
COMPANY_PORT=3001
CUSTOMER_PORT=3002

# =============================================================================
# DATABASE CONFIGURATION - PostgreSQL (REQUIRED)
# =============================================================================
# Format: postgresql://[user[:password]@][netloc][:port][/dbname][?params]
#
# IMPORTANT: Set this in your production environment
# For Render: Use the auto-linked PostgreSQL service (do not hardcode)
# For AWS RDS: Get from RDS console
# For Neon: Get from Neon dashboard
# For self-hosted: Use your PostgreSQL connection string
#
# Example values (update with your actual database):
# Local: postgresql://postgres:password@localhost:5432/rihla_dev
# Neon (pooler): postgresql://user:password@host-pooler.region.postgres.neon.tech/db
# AWS RDS: postgresql://admin:password@instance.region.rds.amazonaws.com:5432/rihla
# Render: Use fromService in render.yaml (auto-linked)
#
DATABASE_URL=postgresql://postgres:password@localhost:5432/rihla

# =============================================================================
# REDIS CACHE CONFIGURATION (REQUIRED)
# =============================================================================
# Required for caching, sessions, and real-time features
#
# Local Development:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Production options:
# - Render Redis: Use fromService in render.yaml (auto-linked)
# - AWS ElastiCache: Update with ElastiCache endpoint
# - Redis Cloud: Get from Redis Cloud dashboard
# - Self-hosted: Provide your Redis host and credentials
#
# Example production values:
# REDIS_HOST=redis-cloud-instance.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-strong-password

# =============================================================================
# JWT AUTHENTICATION SECRET (REQUIRED)
# =============================================================================
# Secret key for signing JWT tokens
# SECURITY CRITICAL: This must be a strong random string
# Minimum: 32 characters, mix of upper/lower/numbers/special characters
#
# Generate a new secure secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ⚠️ IMPORTANT SECURITY NOTES:
# 1. Use a DIFFERENT secret for each environment (dev, staging, prod)
# 2. For production, use 64+ character random string
# 3. Store in secure secret manager (AWS Secrets Manager, HashiCorp Vault, etc.)
# 4. Never commit actual secret to repository
# 5. Rotate secrets periodically
# 6. Changing this invalidates all existing tokens
#
# This is a placeholder - MUST be replaced with actual secret in production
JWT_SECRET=change-me-to-strong-random-string-in-production-minimum-32-characters

# =============================================================================
# CORS CONFIGURATION (REQUIRED)
# =============================================================================
# Comma-separated list of allowed frontend origins
# Only requests from these origins will be accepted
#
# Local Development:
CORS_ORIGINS=http://localhost:4000,http://localhost:4100,http://localhost:4200

# Production - UPDATE WITH YOUR ACTUAL DOMAINS:
# CORS_ORIGINS=https://admin.yourdomain.com,https://company.yourdomain.com,https://customer.yourdomain.com
#
# ⚠️ SECURITY: Be specific, do not use wildcards in production

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Directory for storing uploaded files (for local storage)
# Note: In production, consider using cloud storage (AWS S3, Azure Blob, etc.)
UPLOAD_DIR=./uploads

# Maximum file upload size in bytes
# 52428800 = 50MB (default)
# Adjust based on your requirements
MAX_UPLOAD_SIZE=52428800

# =============================================================================
# WHATSAPP INTEGRATION (OPTIONAL)
# =============================================================================
# Enable/disable WhatsApp notifications
# Only required if you're implementing WhatsApp features
WHATSAPP_ENABLED=false

# Get these values from Meta/WhatsApp Business Console
# Only needed if WHATSAPP_ENABLED=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=

# =============================================================================
# FRONTEND API BASE URLS (For frontend apps)
# =============================================================================
# URLs that frontend applications will use to call the backend APIs
#
# Local Development:
ADMIN_API_URL=http://localhost:3000/api
COMPANY_API_URL=http://localhost:3001/api
CUSTOMER_API_URL=http://localhost:3002/api

# Production - UPDATE WITH YOUR ACTUAL DOMAINS:
# ADMIN_API_URL=https://admin-api.yourdomain.com/api
# COMPANY_API_URL=https://company-api.yourdomain.com/api
# CUSTOMER_API_URL=https://customer-api.yourdomain.com/api

# =============================================================================
# OPTIONAL: PAYMENT GATEWAY CONFIGURATION (For future features)
# =============================================================================
# Stripe Integration
# STRIPE_SECRET_KEY=sk_live_your_secret_key
# STRIPE_PUBLIC_KEY=pk_live_your_public_key

# PayPal Integration
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox|live

# =============================================================================
# OPTIONAL: EMAIL CONFIGURATION (For future features)
# =============================================================================
# SMTP Configuration for sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# OPTIONAL: SMS CONFIGURATION (For future features)
# =============================================================================
# Twilio SMS Integration
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# =============================================================================
# OPTIONAL: LOGGING CONFIGURATION
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATIONS
# =============================================================================

# LOCAL DEVELOPMENT
# Copy this section to .env for local development:
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:password@localhost:5432/rihla_dev
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# JWT_SECRET=dev-local-secret-key-minimum-32-chars-long-here
# CORS_ORIGINS=http://localhost:4000,http://localhost:4100,http://localhost:4200
# ADMIN_API_URL=http://localhost:3000/api
# COMPANY_API_URL=http://localhost:3001/api
# CUSTOMER_API_URL=http://localhost:3002/api

# DOCKER DEVELOPMENT (with docker-compose.yml)
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rihla
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# JWT_SECRET=docker-dev-secret-key-minimum-32-chars-long-here
# CORS_ORIGINS=http://localhost:4000,http://localhost:4100,http://localhost:4200

# RENDER PRODUCTION DEPLOYMENT
# ⚠️ DO NOT hardcode values below - set in Render Dashboard instead
# NODE_ENV=production
# DATABASE_URL=<auto-linked from Render PostgreSQL service>
# REDIS_HOST=<auto-linked from Render Redis service>
# REDIS_PORT=6379
# REDIS_PASSWORD=<auto-linked from Render Redis service>
# JWT_SECRET=<set as secret in Render Dashboard - use strong random 64+ char string>
# CORS_ORIGINS=https://admin.yourdomain.com,https://company.yourdomain.com,https://customer.yourdomain.com
# ADMIN_API_URL=https://admin-api.yourdomain.com/api
# COMPANY_API_URL=https://company-api.yourdomain.com/api
# CUSTOMER_API_URL=https://customer-api.yourdomain.com/api

# AWS PRODUCTION DEPLOYMENT
# NODE_ENV=production
# DATABASE_URL=postgresql://admin:strong-password@rihla-db.region.rds.amazonaws.com:5432/rihla
# REDIS_HOST=rihla-cache.region.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_PASSWORD=strong-password-from-elasticache
# JWT_SECRET=<stored in AWS Secrets Manager - 64+ char random string>
# CORS_ORIGINS=https://admin.yourdomain.com,https://company.yourdomain.com,https://customer.yourdomain.com

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================

# 1. INITIAL SETUP
#    cp backend/.env.example backend/.env
#    Edit backend/.env with your values

# 2. LOCAL DEVELOPMENT
#    a) Start PostgreSQL and Redis (use docker-compose):
#       docker-compose up -d postgres redis
#    b) Run database migrations:
#       npx prisma migrate dev
#    c) Start backend services:
#       npm run start:all

# 3. RENDER DEPLOYMENT
#    a) Create render.yaml with PostgreSQL and Redis services
#    b) Set environment variables in Render Dashboard:
#       - JWT_SECRET (strong random value)
#       - CORS_ORIGINS (your production domains)
#       - WHATSAPP credentials (if needed)
#    c) Database URL auto-linked from PostgreSQL service
#    d) Redis auto-linked from Redis service

# 4. AWS DEPLOYMENT
#    a) Create RDS PostgreSQL instance
#    b) Create ElastiCache Redis instance
#    c) Store secrets in AWS Secrets Manager
#    d) Configure EC2/ECS with environment variables from Secrets Manager

# 5. DOCKER COMPOSE
#    docker-compose up -d
#    Services automatically connect using service names

# =============================================================================
# SECURITY CHECKLIST FOR PRODUCTION
# =============================================================================
# Before deploying to production, verify:
#
# DATABASE
# ✅ DATABASE_URL uses strong password (16+ characters)
# ✅ PostgreSQL user has limited permissions
# ✅ Database backups enabled (automated)
# ✅ SSL/TLS enabled for database connection
# ✅ Database encryption at rest enabled
# ✅ Regular security updates applied
#
# REDIS
# ✅ REDIS_PASSWORD is set (strong, 32+ characters)
# ✅ Redis only accessible from your application VPC
# ✅ Redis persistence enabled (RDB or AOF)
# ✅ Redis encryption in transit enabled
#
# JWT
# ✅ JWT_SECRET is long random string (64+ characters)
# ✅ JWT_SECRET stored in secure secret manager
# ✅ JWT_SECRET NOT exposed in logs or error messages
# ✅ Token expiration set appropriately
# ✅ Separate secrets for each environment
#
# CORS
# ✅ CORS_ORIGINS only includes legitimate production domains
# ✅ No wildcards (*) in production CORS configuration
# ✅ CORS_ORIGINS tested against actual frontend domains
#
# GENERAL
# ✅ .env file is in .gitignore (NEVER commit)
# ✅ All secrets stored in secure manager (AWS Secrets, HashiCorp Vault, etc.)
# ✅ No secrets in application logs
# ✅ No secrets in error messages
# ✅ No secrets in git history
# ✅ Secrets rotated every 90 days
# ✅ Access logs enabled and monitored
# ✅ Application uses HTTPS only in production
# ✅ Security headers configured (HSTS, CSP, etc.)
# ✅ Rate limiting enabled
# ✅ Input validation enabled
# ✅ Output encoding enabled
#
# =============================================================================
# TROUBLESHOOTING
# =============================================================================

# Database connection fails:
# 1. Verify DATABASE_URL is correct: psql $DATABASE_URL
# 2. Check PostgreSQL is running: pg_isready -h localhost
# 3. Verify credentials are correct
# 4. Check firewall rules allow database connection
# 5. In production, check security groups/network ACLs

# Redis connection fails:
# 1. Verify REDIS_HOST and REDIS_PORT are correct
# 2. Check Redis is running: redis-cli -h $REDIS_HOST ping
# 3. If password set, verify REDIS_PASSWORD
# 4. Check firewall rules allow Redis connection

# JWT errors:
# 1. Verify JWT_SECRET is same across all services
# 2. Don't change JWT_SECRET in production (invalidates tokens)
# 3. Check token expiration hasn't occurred

# CORS errors:
# 1. Add frontend URL to CORS_ORIGINS (comma-separated)
# 2. Check exact URL matches (protocol, domain, port)
# 3. Restart backend after CORS_ORIGINS change
# 4. Check browser console for actual origin being used

