# Environment Configuration Example
# Copy this file to .env and update values for your environment

# Node Environment
NODE_ENV=development

# Port Configuration
ADMIN_PORT=3000
COMPANY_PORT=3001
CUSTOMER_PORT=3002

# CORS Configuration (comma-separated URLs)
CORS_ORIGINS=http://localhost:4000,http://localhost:4100,http://localhost:4200

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rihla

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# WhatsApp Configuration (optional)
WHATSAPP_ENABLED=false

# Frontend API Base URLs
ADMIN_API_URL=http://localhost:3000/api
COMPANY_API_URL=http://localhost:3001/api
CUSTOMER_API_URL=http://localhost:3002/api
