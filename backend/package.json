{
  "name": "backend",
  "version": "0.0.1",
  "description": "Bus booking backend microservices",
  "author": "Rihla Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "build:company": "nest build company",
    "build:customer": "nest build customer",
    "build:admin": "nest build admin",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:company": "nest start company",
    "start:customer": "nest start customer",
    "start:admin": "nest start admin",
    "start:all": "concurrently \"npm run start:company\" \"npm run start:customer\" \"npm run start:admin\"",
    "start:dev": "nest start --watch",
    "start:dev:company": "nest start company --watch",
    "start:dev:customer": "nest start customer --watch",
    "start:dev:admin": "nest start admin --watch",
    "start:dev:all": "concurrently \"npm run start:dev:company\" \"npm run start:dev:customer\" \"npm run start:dev:admin\"",
    "start:debug": "nest start --debug --watch",
    "start:debug:company": "nest start company --debug --watch",
    "start:debug:customer": "nest start customer --debug --watch",
    "start:debug:admin": "nest start admin --debug --watch",
    "start:debug:all": "concurrently \"npm run start:debug:company\" \"npm run start:debug:customer\" \"npm run start:debug:admin\"",
    "start:prod": "concurrently \"node dist/apps/company/main\" \"node dist/apps/customer/main\" \"node dist/apps/admin/main\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/backend/test/jest-e2e.json"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/websockets": "^11.1.21",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express-session": "^1.19.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express-session": "^1.19.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfmake": "^0.3.8",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "puppeteer": "^24.43.0",
    "qrcode-terminal": "^0.12.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfmake": "^0.3.2",
    "@types/puppeteer-core": "^5.4.0",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/prisma(|/.*)$": "<rootDir>/libs/prisma/src/$1",
      "^@app/redis(|/.*)$": "<rootDir>/libs/redis/src/$1"
    }
  }
}
